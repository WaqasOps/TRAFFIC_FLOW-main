# Environment Variables Configuration
# Copy this file to .env in root directory for local development
# DO NOT commit .env to version control

# AWS Configuration
AWS_ACCOUNT_ID=your_aws_account_id
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1

# EC2 Configuration
EC2_HOST=your_ec2_public_ip_or_domain
EC2_USER=ubuntu
EC2_SSH_KEY=your_private_ssh_key

# Application Environment
NODE_ENV=production

# Service URLs (for internal communication)
SERVICE_A_URL=http://service-a:3001
SERVICE_B_URL=http://service-b:3002
SERVICE_C_URL=http://service-c:3003
SERVICE_D_URL=http://service-d:3004
SERVICE_E_URL=http://service-e:3005

# Database Configuration (if applicable)
# DB_HOST=your_db_host
# DB_PORT=5432
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=traffic_flow

# Application Logs
LOG_LEVEL=info
