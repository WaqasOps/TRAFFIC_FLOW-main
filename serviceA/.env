# Database Configuration
DB_HOST=postgres                    # PostgreSQL hostname (Docker service name)
DB_PORT=5432                        # PostgreSQL port
DB_USER=admin                       # Database username
DB_PASS=admin                       # Database password
DB_NAME=admin                       # Database name

# Service Configuration
SERVICE_NAME=serviceA               # Service identifier for logging
SERVICE_PORT=3001                   # Port the service runs on

PORT=3001
# Downstream Service URLs
SERVICE_B_URL=http://serviceb:3002/serviceB  # URL to call Service B

# Application Settings
NODE_ENV=development                # Environment (development/production)
LOG_LEVEL=debug                     # Logging level (debug/info/warn/error)