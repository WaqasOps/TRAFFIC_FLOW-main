# Frontend Environment Variables Example
# Copy this file to .env and update values for your environment

# ===== PRIMARY SERVICE ENDPOINT =====
# Main entry point for request chain
REACT_APP_SERVICE_A_URL=http://localhost:3001/serviceA

# ===== HEALTH CHECK ENDPOINTS =====
# Individual service health monitoring URLs
REACT_APP_SERVICE_A_HEALTH=http://localhost:3001/health
REACT_APP_SERVICE_B_HEALTH=http://localhost:3002/health
REACT_APP_SERVICE_C_HEALTH=http://localhost:3003/health
REACT_APP_SERVICE_D_HEALTH=http://localhost:3004/health
REACT_APP_SERVICE_E_HEALTH=http://localhost:3005/health

# ===== APPLICATION SETTINGS =====
# Request timeout in milliseconds (default: 15000 = 15 seconds)
REACT_APP_REQUEST_TIMEOUT=15000

# Enable debug mode for console logging (true/false)
REACT_APP_ENABLE_DEBUG=false
