# frontend/.env
# =================================================================
# Frontend Configuration for Microservices Architecture
# =================================================================

# ===== PRIMARY SERVICE ENDPOINT =====
# Main entry point for request chain when the app is served from the same origin
REACT_APP_SERVICE_A_URL=/api/serviceA/

# ===== HEALTH CHECK ENDPOINTS =====
# Individual service health monitoring URLs
REACT_APP_SERVICE_A_HEALTH=/api/serviceA/health
REACT_APP_SERVICE_B_HEALTH=/api/serviceB/health
REACT_APP_SERVICE_C_HEALTH=/api/serviceC/health
REACT_APP_SERVICE_D_HEALTH=/api/serviceD/health
REACT_APP_SERVICE_E_HEALTH=/api/serviceE/health

# ===== APPLICATION SETTINGS =====
# Request timeout in milliseconds (default: 15000 = 15 seconds)
REACT_APP_REQUEST_TIMEOUT=15000

# Enable debug mode for console logging (true/false)
REACT_APP_ENABLE_DEBUG=true

# ===== ENVIRONMENT-SPECIFIC OVERRIDES =====
# Uncomment and modify for different deployment environments

# --- Development (Local Docker) ---
# REACT_APP_SERVICE_A_URL=http://localhost:3000/serviceA

# --- Production (AWS/ECS) ---
# REACT_APP_SERVICE_A_URL=https://api.yourcompany.com/serviceA
# REACT_APP_SERVICE_A_HEALTH=https://api.yourcompany.com/health
# REACT_APP_SERVICE_B_HEALTH=https://api-b.yourcompany.com/health
# REACT_APP_SERVICE_C_HEALTH=https://api-c.yourcompany.com/health
# REACT_APP_SERVICE_D_HEALTH=https://api-d.yourcompany.com/health
# REACT_APP_SERVICE_E_HEALTH=https://api-e.yourcompany.com/health
# REACT_APP_REQUEST_TIMEOUT=30000
# REACT_APP_ENABLE_DEBUG=false

# --- Staging ---
# REACT_APP_SERVICE_A_URL=https://staging-api.yourcompany.com/serviceA
# REACT_APP_ENABLE_DEBUG=true

# ===== USAGE NOTES =====
# 1. All variables must start with REACT_APP_ to be accessible in React
# 2. Changes require rebuilding the application (npm run build)
# 3. Never commit sensitive credentials to this file
# 4. Use environment-specific .env files (.env.development, .env.production)