# GitHub Secrets Template
# Copy this format to add secrets to your GitHub repository
# Go to: Settings → Secrets and variables → Actions → New repository secret

# ========================
# AWS Configuration
# ========================
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=AKIA1234567890ABCDEF
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1

# ========================
# EC2 Configuration
# ========================
EC2_HOST=54.123.45.67
EC2_USER=ubuntu
EC2_SSH_KEY=-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA7vJ3x8yZ9k2m...
(paste your entire .pem file content here)
...
-----END RSA PRIVATE KEY-----

# ========================
# Database Configuration (REQUIRED)
# ========================
DB_USER=postgres
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_NAME=traffic_flow
DB_PASS=your_secure_password_here
DB_PORT=5432

# ========================
# Environment Configuration
# ========================
NODE_ENV=production
DOCKER_NETWORK=traffic-flow

# ========================
# Service Ports
# ========================
FRONTEND_PORT=80
SERVICE_A_PORT=3001
SERVICE_B_PORT=3002
SERVICE_C_PORT=3003
SERVICE_D_PORT=3004
SERVICE_E_PORT=3005

# ========================
# Container Names
# ========================
CONTAINER_FRONTEND=traffic-flow-frontend
CONTAINER_SERVICE_A=traffic-flow-service-a
CONTAINER_SERVICE_B=traffic-flow-service-b
CONTAINER_SERVICE_C=traffic-flow-service-c
CONTAINER_SERVICE_D=traffic-flow-service-d
CONTAINER_SERVICE_E=traffic-flow-service-e

# ========================
# Frontend Environment Variables (React build-time)
# ========================
# These get baked into the Docker image during build
REACT_APP_SERVICE_A_URL=http://ec2-instance-ip:3001/serviceA
REACT_APP_SERVICE_B_URL=http://ec2-instance-ip:3002/serviceB
REACT_APP_SERVICE_C_URL=http://ec2-instance-ip:3003/serviceC
REACT_APP_SERVICE_D_URL=http://ec2-instance-ip:3004/serviceD
REACT_APP_SERVICE_E_URL=http://ec2-instance-ip:3005/serviceE

REACT_APP_SERVICE_A_HEALTH=http://ec2-instance-ip:3001/health
REACT_APP_SERVICE_B_HEALTH=http://ec2-instance-ip:3002/health
REACT_APP_SERVICE_C_HEALTH=http://ec2-instance-ip:3003/health
REACT_APP_SERVICE_D_HEALTH=http://ec2-instance-ip:3004/health
REACT_APP_SERVICE_E_HEALTH=http://ec2-instance-ip:3005/health

REACT_APP_REQUEST_TIMEOUT=15000
REACT_APP_ENABLE_DEBUG=false
