FROM node:18 AS build
WORKDIR /app

# Build arguments for React environment variables
ARG REACT_APP_SERVICE_A_URL="http://localhost:3001/serviceA"
ARG REACT_APP_SERVICE_B_URL="http://localhost:3002/serviceB"
ARG REACT_APP_SERVICE_C_URL="http://localhost:3003/serviceC"
ARG REACT_APP_SERVICE_D_URL="http://localhost:3004/serviceD"
ARG REACT_APP_SERVICE_E_URL="http://localhost:3005/serviceE"
ARG REACT_APP_SERVICE_A_HEALTH="http://localhost:3001/health"
ARG REACT_APP_SERVICE_B_HEALTH="http://localhost:3002/health"
ARG REACT_APP_SERVICE_C_HEALTH="http://localhost:3003/health"
ARG REACT_APP_SERVICE_D_HEALTH="http://localhost:3004/health"
ARG REACT_APP_SERVICE_E_HEALTH="http://localhost:3005/health"
ARG REACT_APP_REQUEST_TIMEOUT="15000"
ARG REACT_APP_ENABLE_DEBUG="false"

# Copy package files
COPY package*.json ./
RUN npm install

# Copy source code
COPY . .

# Create .env file from build arguments
RUN cat > .env.local << EOF
REACT_APP_SERVICE_A_URL=${REACT_APP_SERVICE_A_URL}
REACT_APP_SERVICE_B_URL=${REACT_APP_SERVICE_B_URL}
REACT_APP_SERVICE_C_URL=${REACT_APP_SERVICE_C_URL}
REACT_APP_SERVICE_D_URL=${REACT_APP_SERVICE_D_URL}
REACT_APP_SERVICE_E_URL=${REACT_APP_SERVICE_E_URL}
REACT_APP_SERVICE_A_HEALTH=${REACT_APP_SERVICE_A_HEALTH}
REACT_APP_SERVICE_B_HEALTH=${REACT_APP_SERVICE_B_HEALTH}
REACT_APP_SERVICE_C_HEALTH=${REACT_APP_SERVICE_C_HEALTH}
REACT_APP_SERVICE_D_HEALTH=${REACT_APP_SERVICE_D_HEALTH}
REACT_APP_SERVICE_E_HEALTH=${REACT_APP_SERVICE_E_HEALTH}
REACT_APP_REQUEST_TIMEOUT=${REACT_APP_REQUEST_TIMEOUT}
REACT_APP_ENABLE_DEBUG=${REACT_APP_ENABLE_DEBUG}
EOF

# Build React app
RUN npm run build

FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
